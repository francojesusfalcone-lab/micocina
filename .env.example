# ─── MercadoPago ─────────────────────────────────────────────────────────────
# Obtené tus credenciales en: https://www.mercadopago.com.ar/developers/panel
# Usá las credenciales de SANDBOX para testing, PRODUCCIÓN para real

# Tu Public Key (no es secreta, va en el frontend)
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Tu Access Token (⚠️ en producción esto debe estar SOLO en el backend)
# Para testing en local, podés ponerlo acá temporalmente
VITE_MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Entorno: 'sandbox' para testing, 'production' para real
VITE_MP_ENV=sandbox
